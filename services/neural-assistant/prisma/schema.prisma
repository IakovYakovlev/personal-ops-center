generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ChatList {
  id            String   @id @default(cuid())
  userId        String
  documentId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())
  isArchived    Boolean  @default(false)
  chats         Chat[]
}

model Chat {
  id         String   @id @default(cuid())
  chatListId String
  content    String
  createdAt  DateTime @default(now())

  chatList ChatList @relation(fields: [chatListId], references: [id], onDelete: Cascade)
}
